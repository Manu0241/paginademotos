:root {
    --color-1: #9debf5;
    --color-2: #FFBE0B;
    --color-3: #3aff75;
    --color-4: #ec3838;
    --color-5: #FB5607;
    --color-6: #a700f5;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: sans-serif;
    font-size: 16px;
}

#principal {
    display: grid;
    grid-template-columns: repeat(3, 120px);
    grid-template-rows: repeat(2, 120px);
    gap: 10px;
    margin: 20px;
}

#principal article {
    display: flex;
    justify-content: center;
    align-items: center;
}

article {
    border: 1px solid black;
    text-align: center;
    padding: 20px;
}

.fila1 { background-color: var(--color-1); }
.fila2 { background-color: var(--color-2); }
.fila3 { background-color: var(--color-3); }
.fila4 { background-color: var(--color-4); }
.fila5 { background-color: var(--color-5); }
.fila6 { background-color: var(--color-6); }

.impar,
.par {
    display: flex;
    flex-direction: column;
    align-items: center;
}

article:nth-child(odd) {
    flex-direction: column-reverse;
}

nav ul {
    display: flex;
    list-style: none;
    background-color: rgba(255, 191, 229, 0.448);

    justify-content: space-around;
    align-items: center;
    max-width: 100dvw;

    height: 2rem;
}

nav ul li {
    border: 1px solid rgb(233, 175, 175);
    font-size: 0.8rem; /* rem multiplica el valor por el tamaño de letra del body */
    padding: 0.5em; /* em multiplica el valor por el tamaño de letra del elemnto */
    width: 8rem;
    text-align: center;
}

nav ul li:hover {
    background-color: rgb(255, 207, 162);
}

nav ul li a {
    text-decoration: none; /* quitamos lo subrayado de los enlaces */
    color: rgb(0, 94, 255);
    font-weight: bold;
}

nav ul li a:hover{
    text-decoration: underline; /* añadimos subrayado al pasar el raton */
}


section#indice img {
    max-width: 150px;
}


/* section#indice {
    display: grid;
    grid-template-columns: 50% auto;
    grid-template-rows: auto auto;
}
 */
section#indice {
    display: grid;
    grid-template-areas: 
    "novedades     novedades     novedades     comparativa comparativa comparativa comparativa comparativa comparativa"
    "novedades     novedades     novedades     comparativa comparativa comparativa comparativa comparativa comparativa"
    "novedades     novedades     novedades     ocasion     ocasion     ocasion     ocasion     ocasion     ocasion"
    "ubicacion     ubicacion     ubicacion     ocasion     ocasion     ocasion     ocasion     ocasion     ocasion"
    "ubicacion     ubicacion     ubicacion     ocasion     ocasion     ocasion     ocasion     ocasion     ocasion"
    "ubicacion     ubicacion     ubicacion     contacto    contacto    contacto    contacto    contacto    contacto"
    "ubicacion     ubicacion     ubicacion     contacto    contacto    contacto    contacto    contacto    contacto"
}





div.indice1_item img {
    max-width: 150px;
}

div#novedades {
    grid-area: novedades;
    background-color: #4a9992;
}

div#comparativa{

    grid-area: comparativa;
    background-color: #f4caff;

}

div#ocasion{
    grid-area: ocasion;
    background-color: #e8f5a5;

}

div#ubicacion{

    grid-area: ubicacion;
    background-color: #b8ff7d;

}

div#contacto{

    grid-area: contacto;
    background-color: #f89595;

}
@media screen and (max-width: 768px) and (min-width: 480px) {
    section#indice {
        display: grid;
        grid-template-areas: 
        "inicio novedades"
        "comparativa contacto"
        "ocasion ubicacion"
    }
    
}
@media screen and (max-width: 480px) {
    main {
        display: grid;
        grid-template-areas: 
        "inicio"
        "novedades"
        "comparativa"
        "contacto"
        "ocasion"
        "ubicacion"
    }
    
} 
    
